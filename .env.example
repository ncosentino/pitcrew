# Reference for the gitignored profile environment files written by
# Setup-Runner.ps1. The default profile uses `.env`; named profiles use
# `.env.<profile>`. Never commit either form because it holds your PAT.

# Written by Setup-Runner.ps1. Token = your -Token PAT, else your gh CLI token
# (gh auth token). The pool uses it ONLY to register/remove runners. Needs
# Administration: Read and write on each repo.
ACCESS_TOKEN=

# Repos the runners attach to (repo scope). Each is "url" or "url=workers"; give a
# heavy repo more, a light one fewer. They don't share - each repo's workers are
# dedicated to it. REPO_URL is a single-repo back-compat alias.
REPO_URLS=https://github.com/me/repo-a=1,https://github.com/me/repo-b=4
# REPO_URL=https://github.com/me/repo-a

# Runner scope: repo (default) | org | ent. Org and enterprise scopes use
# ORG_NAME or ENTERPRISE_NAME and ignore the repository list.
RUNNER_SCOPE=repo
# ORG_NAME=
# ENTERPRISE_NAME=

# Default workers per repo for any entry above without an explicit "=count". For
# org/ent scope (no repo list) this is the total worker count. Each worker is its
# own throwaway container; 1 is safe, raise for more parallelism.
RUNNER_REPLICAS=1

# --- Optional knobs (sensible defaults applied in docker-compose.yml) ----------

# Profile identity. The implicit default profile remains backward compatible.
RUNNER_PROFILE_ID=default

# The runner image each slot launches. The default base already ships PowerShell 7
# and a broad toolchain. To run the asserted variant instead, build it
# (`docker build -t self-hosted-runner:local .`) and set:
# RUNNER_IMAGE=self-hosted-runner:local
# Setup prepares the selected image before starting the manager, so generated
# profile state disables a second pull that could replace a verified mutable tag.
RUNNER_PULL_IMAGE=0

# Prefix for runner names in the GitHub UI (a slot/timestamp suffix is appended).
# RUNNER_NAME_PREFIX=runner

# Extra comma-separated labels. The default profile includes general-purpose.
# Isolated named profiles omit GitHub's default self-hosted/linux/architecture
# labels and receive explicit platform labels from the manager instead.
RUNNER_LABELS=general-purpose
RUNNER_NO_DEFAULT_LABELS=

# Optional organization/enterprise runner group.
# RUNNER_GROUP=