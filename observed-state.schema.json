{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.devleader.ca/projects/pitcrew/schemas/observed-state.schema.json",
  "title": "PitCrew Manager Observed State",
  "description": "Credential-free operational status projected by one PitCrew profile manager.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "resourceUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpuCores",
        "memoryWorkingSetBytes",
        "pids"
      ],
      "properties": {
        "cpuCores": {
          "type": "number",
          "minimum": 0
        },
        "memoryWorkingSetBytes": {
          "type": "integer",
          "minimum": 0
        },
        "pids": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "hostResourceCapacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logicalProcessorCount",
        "memoryBytes"
      ],
      "properties": {
        "logicalProcessorCount": {
          "type": "integer",
          "minimum": 1
        },
        "memoryBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "managerResourceTelemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampledAt",
        "status",
        "host",
        "manager"
      ],
      "properties": {
        "sampledAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "enum": ["available", "partial", "unavailable"]
        },
        "host": {
          "oneOf": [
            {
              "$ref": "#/$defs/hostResourceCapacity"
            },
            {
              "type": "null"
            }
          ]
        },
        "manager": {
          "oneOf": [
            {
              "$ref": "#/$defs/resourceUsage"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "managerContractVersion",
    "profileId",
    "managerInstanceId",
    "managerStatus",
    "observedAt",
    "scope",
    "generation",
    "desiredStateHash",
    "desiredStateStatus",
    "desiredSlots",
    "activeSlots",
    "drainingSlots",
    "slots"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "managerContractVersion": {
      "type": "integer",
      "minimum": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "managerInstanceId": {
      "type": "string",
      "minLength": 1
    },
    "managerStatus": {
      "enum": ["starting", "running", "stopping", "stopped"]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "enum": ["repo", "org", "ent"]
    },
    "generation": {
      "type": "integer",
      "minimum": 0
    },
    "desiredStateHash": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "desiredStateStatus": {
      "enum": ["waiting", "accepted", "invalid", "stale", "conflict"]
    },
    "desiredSlots": {
      "type": "integer",
      "minimum": 0
    },
    "activeSlots": {
      "type": "integer",
      "minimum": 0
    },
    "drainingSlots": {
      "type": "integer",
      "minimum": 0
    },
    "resourceTelemetry": {
      "oneOf": [
        {
          "$ref": "#/$defs/managerResourceTelemetry"
        },
        {
          "type": "null"
        }
      ]
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "repository",
          "desired",
          "processRunning",
          "state",
          "failureCount",
          "backoffSeconds",
          "updatedAt"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "repository": {
            "type": ["string", "null"]
          },
          "desired": {
            "type": "boolean"
          },
          "processRunning": {
            "type": "boolean"
          },
          "state": {
            "enum": ["starting", "online", "backoff", "restarting", "draining", "stopped"]
          },
          "failureCount": {
            "type": "integer",
            "minimum": 0
          },
          "backoffSeconds": {
            "type": "integer",
            "minimum": 0
          },
          "updatedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "resources": {
            "oneOf": [
              {
                "$ref": "#/$defs/resourceUsage"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "managerContractVersion": {
            "minimum": 7
          }
        },
        "required": [
          "managerContractVersion"
        ]
      },
      "then": {
        "required": [
          "resourceTelemetry"
        ],
        "properties": {
          "resourceTelemetry": {
            "$ref": "#/$defs/managerResourceTelemetry"
          },
          "slots": {
            "items": {
              "required": [
                "resources"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceTelemetry": {
            "type": "object",
            "properties": {
              "status": {
                "const": "available"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "resourceTelemetry"
        ]
      },
      "then": {
        "properties": {
          "resourceTelemetry": {
            "properties": {
              "host": {
                "$ref": "#/$defs/hostResourceCapacity"
              },
              "manager": {
                "$ref": "#/$defs/resourceUsage"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceTelemetry": {
            "type": "object",
            "properties": {
              "status": {
                "const": "partial"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "resourceTelemetry"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "resourceTelemetry": {
                "properties": {
                  "host": {
                    "$ref": "#/$defs/hostResourceCapacity"
                  }
                }
              }
            }
          },
          {
            "properties": {
              "resourceTelemetry": {
                "properties": {
                  "manager": {
                    "$ref": "#/$defs/resourceUsage"
                  }
                }
              }
            }
          },
          {
            "properties": {
              "slots": {
                "contains": {
                  "properties": {
                    "resources": {
                      "$ref": "#/$defs/resourceUsage"
                    }
                  },
                  "required": [
                    "resources"
                  ]
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "resourceTelemetry": {
            "type": "object",
            "properties": {
              "status": {
                "const": "unavailable"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "resourceTelemetry"
        ]
      },
      "then": {
        "properties": {
          "resourceTelemetry": {
            "properties": {
              "host": {
                "type": "null"
              },
              "manager": {
                "type": "null"
              }
            }
          },
          "slots": {
            "items": {
              "properties": {
                "resources": {
                  "type": "null"
                }
              }
            }
          }
        }
      }
    }
  ]
}
